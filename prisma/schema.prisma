generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgres://01211b74e1b99a3bda280b6e1edd90a52ad02bd6bec3f9c2dc1f4aeec2cdbf39:sk_9OOXjh1f9NdLNe8SjmJzw@db.prisma.io:5432/postgres?sslmode=require") // Menggunakan URL khusus Prisma dari Vercel
}

model Dataset {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())
  is_active  Int      @default(0)
  records    Record[]
}

model Record {
  id           Int      @id @default(autoincrement())
  dataset_id   Int
  dataset      Dataset  @relation(fields: [dataset_id], references: [id])
  nim          String
  name         String
  birth_date   String
  position     String?
  division     String?
  note         String?
  is_revealed  Int      @default(0)
  revealed_at  DateTime?
}
